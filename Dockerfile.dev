FROM golang:1.23-alpine

WORKDIR /app

# Install Air for hot-reload
RUN go install github.com/air-verse/air@latest

# Copy go mod files first
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Build for verification
RUN go build -o /tmp/main cmd/api/main.go

EXPOSE 8888

CMD ["air"]